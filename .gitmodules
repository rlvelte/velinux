[submodule "config/zsh/zsh-eza"]
	path = config/zsh/zsh-eza
	url = https://github.com/z-shell/zsh-eza.git
[submodule "config/zsh/zsh-autosuggestions"]
	path = config/zsh/zsh-autosuggestions
