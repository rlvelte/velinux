{
  "hyprland/workspaces": {
    "disable-scroll": true,
    "all-outputs": true,
    "format": "{name}",
    "persistent-workspaces": {
      "1": [],
      "2": [],
      "3": [],
      "4": []
    }
  },

  "hyprland/language": {
    "format": "{}",
    "min-length": 5,
    "tooltip": false
  },

  "hyprland/submap": {
    "format": "in {} mode"
  },

  "hyprland/window": {
    "format": "{}",
    "max-length": 50,
    "rewrite": {
      
    },
    "icon": false,
    "icon-size": 16
  },
}
