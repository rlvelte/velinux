{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://velinux.local/schemas/bundle-scheme.json",
  "title": "vlx bundle scheme",
  "description": "Package scheme definition for vlx bundle",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "repos": {
      "type": "array",
      "description": "Zypper repositories to add before installing packages",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["alias", "url"],
        "additionalProperties": false,
        "properties": {
          "alias": {
            "type": "string",
            "description": "Repository alias"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Repository URL (.repo file)"
          }
        }
      }
    },
    "zypper": {
      "type": "array",
      "description": "Packages to install via zypper",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "flatpak": {
      "type": "array",
      "description": "Packages to install via flatpak",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string"
      }
    },
    "pre": {
      "type": "array",
      "description": "Shell commands to run before installing packages",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "post": {
      "type": "array",
      "description": "Shell commands to run after installing packages",
      "minItems": 1,
      "items": { "type": "string" }
    }
  }
}
